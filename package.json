{
  "name": "lumiforge",
  "private": true,
  "version": "0.1.0",
  "description": "灵机工坊 LumiForge：AI Native 一站式智能硬件开发平台",
  "scripts": {
    "dev": "pnpm --parallel --filter @lumiforge/web --filter @lumiforge/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "runtime-fs:pack": "node tools/runtime-fs-pack.mjs",
    "firmware:build-plan": "node tools/firmware-build-plan.mjs",
    "claw:stats": "node tools/clawctl.mjs stats",
    "claw:validate": "node tools/clawctl.mjs validate",
    "claw:test": "node tools/clawctl.mjs test",
    "claw:write-result": "node tools/clawctl.mjs write-result",
    "skills-lab:sync": "node tools/skills-lab-sync.mjs",
    "skills-lab:sync:sample": "node tools/skills-lab-sync.mjs --limit=5",
    "skills-lab:review": "node tools/skills-lab-review.mjs"
  },
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
